# ==============================================
# Smart Cafe Backend - Environment Configuration
# ==============================================
# Copy this file to .env and fill in the values

# Server
NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/smart-cafe
MONGODB_RETRY_COUNT=3
MONGODB_RETRY_DELAY_MS=2000

# JWT Authentication (REQUIRED in production)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Smart Cafe <noreply@smartcafe.com>

# OTP
OTP_EXPIRY_MINUTES=10

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# ML Forecasting Service
FORECAST_SERVICE_URL=http://localhost:5001
